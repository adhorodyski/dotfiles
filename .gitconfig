[alias]
	s = status
	d = diff
	dc = diff --cached
	l = log --oneline --decorate
	wl = worktree list
[core]
	editor = nvim
	pager = delta
	autocrlf = false
[delta]
	navigate = true
	line-numbers = true
[diff]
	colorMoved = default
[push]
	autoSetupRemote = true
[branch]
	sort = -committerdate
[user]
	name = Adam Horodyski
	email = ad.horodyski@gmail.com
	signingkey = EAEF5DA3FA0AB923
[commit]
    	gpgsign = true
[init]
	defaultBranch = main

